{
  "manifest_version": 3,
  "name": "Work Location Tracker",
  "version": "1.0.0",
  "description": "Track daily work location — home or office",
  "permissions": [
    "storage",
    "windows",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}